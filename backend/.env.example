# ===== LLM 配置 =====
# 注意：API Key 也可通过 App 设置页面配置（存储在 data/user_keys.json，优先级高于此文件）
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# 快速模型（闲聊用）
LLM_FAST_MODEL=gpt-4o-mini

# ===== Embedding 配置 =====
EMBED_PROVIDER=dashscope
EMBED_API_KEY=your-dashscope-api-key
EMBED_MODEL=text-embedding-v4
EMBED_DIMENSION=1024

# ===== JWT 配置 =====
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== 数据库配置 =====
DATABASE_URL=sqlite+aiosqlite:///./data/mellow.db
LANCEDB_PATH=./data/lancedb

# ===== 语音配置（火山引擎）=====
ASR_PROVIDER=volcano
ASR_APP_ID=your-asr-app-id
ASR_TOKEN=your-asr-token
TTS_PROVIDER=volcano
TTS_APP_ID=your-tts-app-id
TTS_TOKEN=your-tts-token

# ===== 主动联系配置 =====
PROACTIVE_CHECK_INTERVAL_MINUTES=15
